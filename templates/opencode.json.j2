{
  "$schema": "https://opencode.ai/config.json",
	"plugin": ["@warp-dot-dev/opencode-warp"],
	"formatter": true,
	"lsp": true,
	"compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "coverage/**", "build/**"]
  },
  "model": "openai/gpt-5.6-sol",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "description": "Planning and analysis agent using OpenAI GPT-5.6 Sol",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "build": {
      "description": "Build agent using OpenAI GPT-5.6 Terra with High variant",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "prompt": "{file:./prompts/build.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "researcher": {
      "description": "Research agent using OpenAI GPT-5.6 Sol for deep analysis and documentation research",
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "debugger": {
      "description": "Debug and testing agent using OpenAI GPT-5.6 Terra with High variant",
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "temperature": 0.3,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "code-reviewer": {
      "description": "Code review agent using OpenAI GPT-5.6 Terra for code quality and best practices",
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "temperature": 0.5,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
